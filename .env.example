# GCP Billing Agent - Environment Variables
# Copy to .env for local testing (never commit .env to git)

# ── GCP Project ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ORG_ID=123456789012

# ── BigQuery Billing Export ───────────────────────────────────────────────────
# Dataset name you configured in GCP Console → Billing → Billing Export
BQ_PROJECT_ID=your-gcp-project-id       # usually same as GCP_PROJECT_ID
BQ_BILLING_DATASET=billing_export
BQ_BILLING_TABLE=gcp_billing_export_v1  # standard table name from GCP

# ── Vertex AI (required - avoids WIF OAuth token conflicts) ──────────────────
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#gcp-billing-alerts

# ── Reports ───────────────────────────────────────────────────────────────────
REPORTS_DIR=/tmp/billing_reports
